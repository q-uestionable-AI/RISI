{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/q-uestionable-AI/RISI/schemas/decision.schema.json",
  "title": "RISI proposed decision",
  "description": "Synthetic proposed decision scored by an external evaluator and never executed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "episode_id",
    "action",
    "rationale_memory_ids",
    "parameters"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "episode_id": { "type": "string", "minLength": 1 },
    "action": { "type": "string", "minLength": 1 },
    "rationale_memory_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "parameters": { "$ref": "#/$defs/jsonObject" }
  },
  "$defs": {
    "jsonObject": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/jsonValue" }
    },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "integer", "boolean", "null"] },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    }
  }
}
