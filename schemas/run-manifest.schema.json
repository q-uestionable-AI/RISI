{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/q-uestionable-AI/RISI/schemas/run-manifest.schema.json",
  "title": "RISI guarded run manifest",
  "description": "Exact capability and resource request for one local-reference run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "profile",
    "scenario_path",
    "scenario_sha256",
    "seed",
    "adapter",
    "decision_provider",
    "policy",
    "capabilities",
    "limits"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
    "profile": { "const": "local-reference" },
    "scenario_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "scenario_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "seed": { "type": "integer", "minimum": 0 },
    "adapter": { "const": "reference" },
    "decision_provider": { "const": "deterministic-approval" },
    "policy": { "const": "pure-read" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "scenario.read",
          "artifact.write",
          "reference.execute",
          "evidence.verify"
        ]
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episodes",
        "retrieval_calls",
        "logical_steps",
        "input_bytes",
        "memory_records",
        "artifact_bytes"
      ],
      "properties": {
        "episodes": { "type": "integer", "minimum": 1 },
        "retrieval_calls": { "type": "integer", "minimum": 1 },
        "logical_steps": { "type": "integer", "minimum": 1 },
        "input_bytes": { "type": "integer", "minimum": 1 },
        "memory_records": { "type": "integer", "minimum": 1 },
        "artifact_bytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
