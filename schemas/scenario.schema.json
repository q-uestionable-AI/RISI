{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/q-uestionable-AI/RISI/schemas/scenario.schema.json",
  "title": "RISI synthetic scenario",
  "description": "Strict paired-episode scenario contract for RISI-C and core CRAF research.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "domain",
    "phenomenon",
    "world_state",
    "principals",
    "initial_memories",
    "evaluator_only",
    "attacker_model",
    "reference_run",
    "seeds"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "scenario_id": { "type": "string", "minLength": 1 },
    "domain": {
      "enum": ["software_deployment", "data_privacy", "synthetic_medication", "approval", "access"]
    },
    "phenomenon": { "enum": ["risi", "craf", "combined"] },
    "world_state": { "$ref": "#/$defs/worldState" },
    "principals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/principal" }
    },
    "initial_memories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/memory" }
    },
    "evaluator_only": { "$ref": "#/$defs/evaluatorOnly" },
    "baseline_history": {
      "type": "array",
      "items": { "$ref": "#/$defs/baselineEpisode" }
    },
    "attacker_model": { "$ref": "#/$defs/attackerModel" },
    "reference_run": { "$ref": "#/$defs/referenceRun" },
    "risi": { "$ref": "#/$defs/risiCondition" },
    "craf": { "$ref": "#/$defs/crafCondition" },
    "nuisance_factors": { "$ref": "#/$defs/jsonObject" },
    "seeds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0 },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "phenomenon": { "const": "risi" } } },
      "then": { "required": ["risi"] }
    },
    {
      "if": { "properties": { "phenomenon": { "const": "craf" } } },
      "then": { "required": ["craf"] }
    },
    {
      "if": { "properties": { "phenomenon": { "const": "combined" } } },
      "then": { "required": ["risi", "craf"] }
    }
  ],
  "$defs": {
    "worldState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_time", "facts", "policies"],
      "properties": {
        "logical_time": { "type": "integer", "minimum": 0 },
        "facts": { "$ref": "#/$defs/jsonObject" },
        "policies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal_id", "role", "tenant_id", "authorities"],
      "properties": {
        "principal_id": { "type": "string", "minLength": 1 },
        "role": { "enum": ["trusted", "victim", "attacker", "decision"] },
        "tenant_id": { "type": "string", "minLength": 1 },
        "authorities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_id",
        "content",
        "tenant_id",
        "owner_id",
        "source_id",
        "access_policy",
        "logical_created_at",
        "logical_valid_from",
        "logical_valid_until",
        "state",
        "metadata"
      ],
      "properties": {
        "memory_id": { "type": "string", "minLength": 1 },
        "content": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": "string", "minLength": 1 },
        "owner_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "access_policy": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "logical_created_at": { "type": "integer", "minimum": 0 },
        "logical_valid_from": { "type": "integer", "minimum": 0 },
        "logical_valid_until": { "type": ["integer", "null"], "minimum": 0 },
        "state": { "enum": ["current", "superseded", "hidden", "archived", "deleted"] },
        "metadata": { "$ref": "#/$defs/jsonObject" }
      }
    },
    "evaluatorOnly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["world_state_hash", "memory_oracles", "decision_oracle"],
      "properties": {
        "world_state_hash": { "$ref": "#/$defs/hash" },
        "memory_oracles": {
          "type": "array",
          "items": { "$ref": "#/$defs/memoryOracle" }
        },
        "decision_oracle": { "$ref": "#/$defs/decisionOracle" }
      }
    },
    "memoryOracle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_id",
        "oracle_truth",
        "oracle_criticality",
        "applicability"
      ],
      "properties": {
        "memory_id": { "type": "string", "minLength": 1 },
        "oracle_truth": { "type": "boolean" },
        "oracle_criticality": { "type": "boolean" },
        "applicability": { "$ref": "#/$defs/jsonObject" }
      }
    },
    "decisionOracle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oracle_id", "safe_actions"],
      "properties": {
        "oracle_id": { "type": "string", "minLength": 1 },
        "safe_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "baselineEpisode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["episode_id", "policy", "safe_decision"],
      "properties": {
        "episode_id": { "type": "string", "minLength": 1 },
        "policy": { "type": "string", "minLength": 1 },
        "safe_decision": { "type": "boolean" }
      }
    },
    "attackerModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal_id", "legitimate_purpose", "allowed_operations", "budget", "truth_constraints"],
      "properties": {
        "principal_id": { "type": "string", "minLength": 1 },
        "legitimate_purpose": { "type": "string", "minLength": 1 },
        "allowed_operations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "budget": { "$ref": "#/$defs/budget" },
        "truth_constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["world_entailed_only", "instructions_prohibited", "contradictions_prohibited"],
          "properties": {
            "world_entailed_only": { "const": true },
            "instructions_prohibited": { "const": true },
            "contradictions_prohibited": { "const": true }
          }
        }
      }
    },
    "referenceRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principal_id",
        "tenant_id",
        "query",
        "top_k",
        "approval_count_fact",
        "minimum_approvals",
        "required_memory_id",
        "action_if_below",
        "action_if_met"
      ],
      "properties": {
        "principal_id": { "type": "string", "minLength": 1 },
        "tenant_id": { "type": "string", "minLength": 1 },
        "query": { "type": "string", "minLength": 1 },
        "top_k": { "type": "integer", "minimum": 1 },
        "approval_count_fact": { "type": "string", "minLength": 1 },
        "minimum_approvals": { "type": "integer", "minimum": 1 },
        "required_memory_id": { "type": "string", "minLength": 1 },
        "action_if_below": { "type": "string", "minLength": 1 },
        "action_if_met": { "type": "string", "minLength": 1 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interactions", "retrieval_calls", "input_tokens", "admitted_memories", "elapsed_logical_time"],
      "properties": {
        "interactions": { "type": "integer", "minimum": 0 },
        "retrieval_calls": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "admitted_memories": { "type": "integer", "minimum": 0 },
        "elapsed_logical_time": { "type": "integer", "minimum": 0 }
      }
    },
    "risiCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_memory_ids", "hidden_retrieval", "observer"],
      "properties": {
        "candidate_memory_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "hidden_retrieval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["memory_id", "logical_time"],
          "properties": {
            "memory_id": { "type": "string", "minLength": 1 },
            "logical_time": { "type": "integer", "minimum": 0 }
          }
        },
        "observer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["principal_id", "allowed_observation_fields", "query_budget"],
          "properties": {
            "principal_id": { "type": "string", "minLength": 1 },
            "allowed_observation_fields": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "query_budget": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "crafCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critical_memory_id",
        "close_distractor_ids",
        "unrelated_distractor_ids",
        "obsolete_memory_id",
        "required_safe_action"
      ],
      "properties": {
        "critical_memory_id": { "type": "string", "minLength": 1 },
        "close_distractor_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "unrelated_distractor_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "obsolete_memory_id": { "type": "string", "minLength": 1 },
        "required_safe_action": { "type": "string", "minLength": 1 }
      }
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/jsonValue" }
    },
    "jsonValue": {
      "oneOf": [
        { "type": ["string", "number", "integer", "boolean", "null"] },
        { "type": "array", "items": { "$ref": "#/$defs/jsonValue" } },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jsonValue" }
        }
      ]
    }
  }
}
